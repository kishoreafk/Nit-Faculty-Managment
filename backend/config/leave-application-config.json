{
  "configFiles": {
    "leaveTypes": "./leave-types.json",
    "formTemplates": "./leave-form-templates.json"
  },
  "systemSettings": {
    "maxAdvanceApplicationDays": 90,
    "minAdvanceApplicationDays": 1,
    "autoCalculateDays": true,
    "allowWeekendLeave": true,
