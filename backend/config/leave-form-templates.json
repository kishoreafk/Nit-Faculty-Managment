{
  "formTemplates": {
    "teaching": {
      "casual": {
        "templateName": "Teaching Faculty Casual Leave Application",
        "formType": "casual_leave_teaching",
        "adjustmentRequired": true,
        "fields": [
          {
            "name": "leave_type",
            "label": "Leave Type",
            "type": "text",
            "required": true,
            "defaultValue": "Casual Leave",
            "readonly": true,
            "autoFill": true
          },
          {
            "name": "name",
            "label": "Faculty Name",
            "type": "text",
            "required": true,
            "autoFill": "faculty_name",
            "readonly": true
          },
          {
            "name": "designation",
            "label": "Designation",
            "type": "text",
            "required": true,
            "autoFill": "designation",
            "readonly": true
          },
          {
            "name": "department",
            "label": "Department",
            "type": "text",
            "required": true,
            "autoFill": "department",
            "readonly": true
          },
          {
            "name": "employee_id",
            "label": "Employee ID",
            "type": "text",
            "required": true,
            "autoFill": "employee_id",
            "readonly": true
          },
          {
            "name": "leave_start_date",
            "label": "Leave Start Date",
            "type": "date",
            "required": true
          },
          {
            "name": "leave_end_date",
            "label": "Leave End Date",
            "type": "date",
            "required": true
          },
          {
            "name": "no_of_days_leave",
            "label": "Number of Days",
            "type": "number",
            "required": true,
            "autoCalculate": true,
            "readonly": true
          },
          {
            "name": "reason",
            "label": "Reason for Leave",
            "type": "textarea",
            "required": true,
            "placeholder": "Please provide detailed reason for leave"
          },
          {
            "name": "adjustment_duties",
            "label": "Adjustment Duties",
            "type": "adjustment_table",
            "required": true,
            "tableConfig": {
              "columns": [
                {
                  "name": "adjustment_faculty_name",
                  "label": "Faculty Name",
                  "type": "text",
                  "required": true,
                  "placeholder": "Name of adjusting faculty"
                },
                {
                  "name": "subject_code",
                  "label": "Subject Code",
                  "type": "text",
                  "required": true,
                  "placeholder": "e.g., CS101"
                },
                {
                  "name": "subject_name",
                  "label": "Subject Name",
                  "type": "text",
                  "required": true,
                  "placeholder": "e.g., Data Structures"
                },
                {
                  "name": "class_section",
                  "label": "Class/Section",
                  "type": "text",
                  "required": true,
                  "placeholder": "e.g., B.Tech CSE 3rd Year A"
                },
                {
                  "name": "date",
                  "label": "Date",
                  "type": "date",
                  "required": true
                },
                {
                  "name": "time_from",
                  "label": "From Time",
                  "type": "time",
                  "required": true
                },
                {
                  "name": "time_to",
                  "label": "To Time",
                  "type": "time",
                  "required": true
                },
                {
                  "name": "period_number",
                  "label": "Period",
                  "type": "number",
                  "required": false,
                  "placeholder": "Period number"
                },
                {
                  "name": "adjustment_type",
                  "label": "Type",
                  "type": "select",
                  "required": true,
                  "options": ["class", "duty", "exam", "other"]
                },
                {
                  "name": "notes",
                  "label": "Notes",
                  "type": "text",
                  "required": false,
                  "placeholder": "Additional notes"
                }
              ],
              "minRows": 1,
              "maxRows": 10,
              "addButtonText": "Add Adjustment",
              "removeButtonText": "Remove"
            }
          },
          {
            "name": "contact_during_leave",
            "label": "Contact During Leave",
            "type": "text",
            "required": false,
            "placeholder": "Phone number or email for emergency contact"
          },
          {
            "name": "application_date",
            "label": "Application Date",
            "type": "date",
            "required": true,
            "autoFill": "current_date",
            "readonly": true
          },
          {
            "name": "application_status",
            "label": "Status",
            "type": "text",
            "required": true,
            "defaultValue": "Pending",
            "readonly": true,
            "autoFill": true
          }
        ]
      },
